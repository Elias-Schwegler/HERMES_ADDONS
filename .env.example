# HERMES_ADDONS — environment template. Copy to .env and fill in YOUR values.
# NEVER commit the real .env (it's gitignored). These are secret NAMES only.

# LiteLLM router master key (clients use this to reach :4002)
LITELLM_MASTER_KEY=sk-litellm-REPLACE_ME

# Unsloth Studio API key (proxy/keepalive + OpenCode use this to reach Studio)
STUDIO_API_KEY=sk-unsloth-REPLACE_ME

# Endpoints (defaults usually fine)
LITELLM_BASE_URL=http://127.0.0.1:4002/v1
STUDIO_BASE_URL=http://127.0.0.1:8888
PROXY_URL=http://127.0.0.1:8889/v1        # Ollama-style autoreload proxy → Studio

# Paths
OBSIDIAN_VAULT=/home/elias/Dokumente/obsidian-vault
HF_HOME=/home/elias/.cache/huggingface
