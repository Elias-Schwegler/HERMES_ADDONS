# /etc/default/hermes-coder — config for the Hermes coder platform.
#
# OOM guard: minimum MemAvailable (GB) required before the coder model is loaded.
# The model needs ~30GB; below this, hermes-coder refuses to load (fail-closed) so a
# unified-memory over-commit can't OOM-cascade the host. Raise for more headroom.
CODER_MIN_AVAIL_GB=34
