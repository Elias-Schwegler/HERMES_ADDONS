# Configuration for /usr/local/bin/unsloth-keepalive (and proxy)
# Sourced by both unsloth-keepalive.service and unsloth-autoreload-proxy.service

# Required — any valid Studio API key. Studio persists keys in auth.db so old
# keys remain valid across restarts; pick the one you keep around.
STUDIO_API_KEY=sk-unsloth-REPLACE_ME

STUDIO_BASE_URL=http://127.0.0.1:8888

# Idle thresholds — when both are exceeded, model is auto-unloaded.
# EXTERNAL = /v1/* hits (Hermes, OpenAI clients). Aggressive default.
# UI       = /api/inference/{chat,generate,audio}* hits (browser activity).
EXTERNAL_IDLE_SECONDS=600
UI_IDLE_SECONDS=1800

CHECK_INTERVAL_SECONDS=60

# State file shared between keepalive and proxy (records last loaded model
# so proxy can re-load it on cold-start requests).
STATE_FILE=/run/unsloth-keepalive/state.json

# Proxy settings
PROXY_HOST=127.0.0.1
PROXY_PORT=8889
LOAD_TIMEOUT_SECONDS=180

# Fallback model used by proxy if state file is missing on first request.
FALLBACK_MODEL=unsloth/Qwen3.6-35B-A3B-MTP-GGUF
FALLBACK_GGUF_VARIANT=UD-Q4_K_XL

# Curated list of GGUF models exposed via /v1/models — comma-separated,
# format: "model_path:gguf_variant". Hermes' /model dropdown shows these.
EXPOSED_MODELS=unsloth/Qwen3.6-35B-A3B-MTP-GGUF:UD-Q4_K_XL,unsloth/Qwen3.6-27B-MTP-GGUF:UD-Q4_K_XL,deepreinforce-ai/Ornith-1.0-35B-GGUF:Q5_K_M
